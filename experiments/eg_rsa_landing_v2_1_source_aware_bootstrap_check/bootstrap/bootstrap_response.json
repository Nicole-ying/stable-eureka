        "description": "Reward horizontal closeness to target center",
        "formula": "sub(1.0, min(abs(x_pos), 1.0))"
      },
      {
        "name": "altitude_progress",
        "description": "Reward low altitude using exponential decay",
        "formula": "exp(-abs(y_pos))"
      },
      {
        "name": "stability",
        "description": "Reward small tilt angle and angular velocity",
        "formula": "sub(1.0, min(add(abs(tilt_angle), abs(angular_vel)), 1.0))"
      },
      {
        "name": "control_cost",
        "description": "Penalize main engine and side engine usage",
        "formula": "neg(add(mul(0.1, main_engine), mul(0.1, abs(side_engine))))"
      },
      {
        "name": "tilt_safety",
        "description": "Extra penalty if tilt exceeds 0.5 rad",
        "formula": "if gt(abs(tilt_angle), 0.5) then -abs(tilt_angle) else 0"
      },
      {
        "name": "landing_success",
        "description": "Terminal reward for stable upright landing with both legs",
        "formula": "reward 100 if left_leg_contact and right_leg_contact and abs(tilt_angle)<0.1 and abs(y_vel)<0.2"
      }
    ],
    "anti_exploit_principles": [
      "Use clipped and bounded rewards to avoid unbounded exploitation.",
      "Prevent reward hacking by ensuring progress rewards require actual progress, not just abstaining from control.",
      "Terminal reward condition must be strict to avoid rewarding crashes.",
