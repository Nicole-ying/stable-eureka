{
  "version": 1,
  "purpose": "Generated primitive task interface inferred inside BootstrapAgent from anonymized task/source input.",
  "input_boundary": "anonymous_source_to_primitive_interface",
  "identity_hidden_from_llm": true,
  "raw_env_code_input": false,
  "env_code_parser": "source_aware_bootstrap_agent",
  "task_description": "Guide a small controlled vehicle to make a safe landing at the target zone. A good policy should approach the target center, descend gently, remain upright, use limited control effort, and finish with stable ground contact instead of bouncing or crashing.",
  "observation_variables": [
    {
      "name": "x_pos",
      "description": "horizontal position relative to target center",
      "type": "float"
    },
    {
      "name": "y_pos",
      "description": "vertical position",
      "type": "float"
    },
    {
      "name": "x_vel",
      "description": "horizontal velocity",
      "type": "float"
    },
    {
      "name": "y_vel",
      "description": "vertical velocity",
      "type": "float"
    },
    {
      "name": "tilt_angle",
      "description": "body tilt angle",
      "type": "float"
    },
    {
      "name": "angular_vel",
      "description": "angular velocity",
      "type": "float"
    },
    {
      "name": "left_leg_contact",
      "description": "whether the left support leg is touching the ground",
      "type": "bool"
    },
    {
      "name": "right_leg_contact",
      "description": "whether the right support leg is touching the ground",
      "type": "bool"
    }
  ],
  "action_variables": [
    {
      "name": "main_engine",
      "description": "main engine thrust (0 or 1)",
      "type": "float"
    },
    {
      "name": "side_engine",
      "description": "side engine thrust (-1 to 1)",
      "type": "float"
    }
  ],
  "allowed_formula_variables": [
    "x_pos",
    "y_pos",
    "x_vel",
    "y_vel",
    "tilt_angle",
    "angular_vel",
    "left_leg_contact",
    "right_leg_contact",
    "main_engine",
    "side_engine"
  ],
  "allowed_formula_functions": [
    "abs",
    "min",
    "max",
    "clip",
    "sqrt",
    "exp",
    "tanh"
  ],
  "allowed_component_types_v2": [
    "formula_component",
    "conditional_formula_component",
    "event_predicate"
  ],
  "bootstrap_requirements": {
    "must_generate_initial_schema": true,
    "must_generate_diagnostic_predicates": true,
    "must_assign_semantic_roles": true,
    "must_include_hacking_risk_notes": true,
    "official_environment_reward_forbidden_as_feedback": true,
    "posthoc_oracle_evaluation_allowed": true,
    "no_v1_schema_exposure": true,
    "no_v1_diagnostic_metric_exposure": true,
    "no_v1_task_description_file_exposure": true,
    "formula_must_use_only_primitive_variables": true
  },
  "semantic_roles": [
    "dense_guidance",
    "stability_quality",
    "terminal_success",
    "safety_constraint",
    "control_cost"
  ],
  "observation_mapping": {
    "x_pos": 0,
    "y_pos": 1,
    "x_vel": 2,
    "y_vel": 3,
    "tilt_angle": 4,
    "angular_vel": 5,
    "left_leg_contact": 6,
    "right_leg_contact": 7
  },
  "bootstrap_interface_policy": {
    "principle": "Reward bootstrap receives a derived interface, not a runtime environment name.",
    "formula_boundary": "Generated formulas must use only allowed_formula_variables and allowed_formula_functions.",
    "not_exposed_to_llm": [
      "runtime environment name",
      "gym_id",
      "benchmark name",
      "previous reward schema"
    ]
  },
  "action_mapping": {
    "type": "discrete_lookup",
    "variables": {
      "main_engine": {
        "0": 0.0,
        "1": 0.0,
        "2": 1.0,
        "3": 0.0,
        "default": 0.0
      },
      "side_engine": {
        "0": 0.0,
        "1": 1.0,
        "2": 0.0,
        "3": -1.0,
        "default": 0.0
      }
    }
  }
}