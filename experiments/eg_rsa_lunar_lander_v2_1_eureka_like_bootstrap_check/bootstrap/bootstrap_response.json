  "diagnostics": {
    "expected_failure_modes": [
      "Hovering indefinitely to collect dense rewards without landing.",
      "Crashing aggressively to end episode early and avoid negative control cost.",
      "Landing on one leg while fulfilling most dense criteria, bypassing terminal success."
    ],
    "risk_notes": [
      "Dense rewards may dominate if terminal success is too infrequent; weight tuning needed.",
      "Lack of explicit crash penalty may encourage unsafe descents; future safety constraints could mitigate.",
      "All formulas use only primitive variables, avoiding hidden state leakage."
    ]
  },
  "bootstrap_report": {
    "design_rationale": "The schema combines continuous guidance for approach (center, speed, orientation) with a large sparse bonus for a successful soft landing on both legs. Control penalties discourage wasteful thrust. No crash penalty is included at this stage to keep the initial schema simple and avoid reliance on unobserved terminal states.",
    "assumptions": [
      "The landing pad center corresponds to x=0.",
      "Both leg contacts imply stable ground contact and termination.",
      "The environment terminates shortly after both legs contact, so a one-time event is sufficient."
    ],
    "risk_notes": [
      "Dense rewards may incentivize hovering; weight scaling ensures terminal bonus outweighs accumulated dense rewards over a typical episode.",
      "Crash states are not explicitly penalized; adding a safety component later may be required."
    ],
