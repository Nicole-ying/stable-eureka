{
  "reward_blueprint": {
    "task_objective": "Land the lunar module safely between the flags, with minimal horizontal offset, low speed, upright orientation, and gentle touchdown without bouncing or crashing.",
    "primitive_variable_roles": {
      "progress_variables": [
        "x"
      ],
      "safety_variables": [
        "vy",
        "angle",
        "angular_velocity",
        "y"
      ],
      "terminal_evidence_variables": [
        "left_contact",
        "right_contact",
        "y"
      ],
      "control_variables": [
        "main_engine",
        "side_engine"
      ]
    },
    "phase_structure": [
      {
        "name": "approach",
        "condition": "y > 0.5",
        "active_rewards": [
          "r_center_guidance",
          "r_stability",
          "r_vertical_safety",
          "r_fuel_penalty"
        ]
      },
      {
        "name": "final_descent",
        "condition": "y <= 0.5",
        "active_rewards": [
          "r_center_guidance",
          "r_stability",
          "r_vertical_safety",
          "r_fuel_penalty"
        ]
      }
    ],
    "component_blueprint": [
      {
        "name": "r_center_guidance",
        "semantic_role": "dense_guidance",
        "description": "Reward for proximity to landing pad center (|x| ≤ 0.2)."
      },
      {
        "name": "r_stability",
        "semantic_role": "stability_quality",
        "description": "Penalize tilt angle and angular velocity."
      },
      {
        "name": "r_vertical_safety",
        "semantic_role": "safety_constraint",
        "description": "Penalize high downward speed when near ground (y < 0.5)."
      },
      {
        "name": "r_fuel_penalty",
        "semantic_role": "control_cost",
        "description": "Small penalty for using main and side engines."
      }
    ],
    "anti_exploit_principles": [
      "Discourage hovering by penalizing fuel usage and rewarding progress toward center.",
      "Prevent bouncing by requiring sustained ground contact for terminal success.",
      "Penalize crashing with negative sparse reward."
    ]
  },
