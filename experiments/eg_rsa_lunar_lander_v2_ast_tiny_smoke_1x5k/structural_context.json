{
  "available_events": [
    "both_contact",
    "centered",
    "contact",
    "engine_on",
    "left_contact",
    "right_contact",
    "safe_contact",
    "slow_vx",
    "slow_vy",
    "stable_landing_condition",
    "upright"
  ],
  "event_specs": {
    "left_contact": {
      "type": "threshold_gt",
      "var": "left_contact",
      "threshold": 0.5
    },
    "right_contact": {
      "type": "threshold_gt",
      "var": "right_contact",
      "threshold": 0.5
    },
    "contact": {
      "type": "any",
      "events": [
        "left_contact",
        "right_contact"
      ]
    },
    "both_contact": {
      "type": "all",
      "events": [
        "left_contact",
        "right_contact"
      ]
    },
    "centered": {
      "type": "threshold_abs",
      "var": "x",
      "threshold": 0.25
    },
    "slow_vx": {
      "type": "threshold_abs",
      "var": "vx",
      "threshold": 0.4
    },
    "slow_vy": {
      "type": "threshold_abs",
      "var": "vy",
      "threshold": 0.4
    },
    "upright": {
      "type": "threshold_abs",
      "var": "angle",
      "threshold": 0.4
    },
    "safe_contact": {
      "type": "all",
      "events": [
        "contact",
        "slow_vx",
        "slow_vy",
        "upright"
      ]
    },
    "stable_landing_condition": {
      "type": "all",
      "events": [
        "both_contact",
        "centered",
        "slow_vx",
        "slow_vy",
        "upright"
      ]
    },
    "engine_on": {
      "type": "action_nonzero"
    }
  },
  "available_task_metrics": [
    "approach_region_score",
    "energy_cost",
    "landing_quality",
    "landing_region_score",
    "progress",
    "stability",
    "success",
    "two_leg_contact_evidence",
    "velocity_smoothness"
  ],
  "task_metric_specs": {
    "success": {
      "type": "event_success",
      "event": "stable_landing_condition"
    },
    "landing_region_score": {
      "type": "target_region",
      "inputs": [
        "x"
      ],
      "center": [
        0.0
      ],
      "tolerance": [
        0.25
      ]
    },
    "approach_region_score": {
      "type": "target_region",
      "inputs": [
        "x",
        "y"
      ],
      "center": [
        0.0,
        0.0
      ],
      "tolerance": [
        1.0,
        1.0
      ]
    },
    "velocity_smoothness": {
      "type": "raw_abs_inverse",
      "inputs": [
        "vx",
        "vy"
      ]
    },
    "stability": {
      "type": "bounded_stability",
      "inputs": [
        "angle",
        "angular_velocity"
      ],
      "scales": [
        0.4,
        0.5
      ]
    },
    "landing_quality": {
      "type": "metric_mean",
      "metrics": [
        "landing_region_score",
        "velocity_smoothness",
        "stability"
      ]
    },
    "progress": {
      "type": "metric_mean",
      "metrics": [
        "landing_region_score",
        "velocity_smoothness",
        "stability"
      ]
    },
    "energy_cost": {
      "type": "action_cost"
    },
    "two_leg_contact_evidence": {
      "type": "event_score",
      "event": "both_contact"
    }
  },
  "preferred_success_events": [
    "stable_landing_condition"
  ],
  "allowed_formula_variables": [
    "x",
    "y",
    "vx",
    "vy",
    "angle",
    "angular_velocity",
    "left_contact",
    "right_contact",
    "main_engine",
    "side_engine"
  ],
  "allowed_formula_functions": [
    "abs",
    "min",
    "max",
    "clip",
    "sqrt",
    "exp",
    "tanh"
  ],
  "semantic_roles": [
    "dense_guidance",
    "stability_quality",
    "terminal_success",
    "safety_constraint",
    "control_cost"
  ],
  "action_variables": [
    {
      "name": "main_engine",
      "description": "Main engine action or throttle.",
      "type": "float"
    },
    {
      "name": "side_engine",
      "description": "Side engine action or throttle.",
      "type": "float"
    }
  ],
  "action_mapping": {
    "type": "discrete_lookup",
    "variables": {
      "main_engine": {
        "2": 1.0,
        "default": 0.0
      },
      "side_engine": {
        "1": -1.0,
        "3": 1.0,
        "default": 0.0
      }
    }
  },
  "primitive_interface": {
    "version": 1,
    "env": "LunarLander-v3",
    "purpose": "Primitive-only task interface for EG-RSA-V2. This file exposes primitive observation/action variables, allowed formula variables, allowed formula functions, semantic roles, and task text. It does not expose any previous reward schema or previous diagnostic/event definitions.",
    "task_description": "Land the lunar module safely between the flags. A good landing should be centered, slow, upright, fuel-efficient, and should end with stable ground contact rather than bouncing or crashing.",
    "observation_variables": [
      {
        "name": "x",
        "description": "Horizontal position relative to landing pad center.",
        "type": "float"
      },
      {
        "name": "y",
        "description": "Vertical position.",
        "type": "float"
      },
      {
        "name": "vx",
        "description": "Horizontal velocity.",
        "type": "float"
      },
      {
        "name": "vy",
        "description": "Vertical velocity.",
        "type": "float"
      },
      {
        "name": "angle",
        "description": "Lander tilt angle.",
        "type": "float"
      },
      {
        "name": "angular_velocity",
        "description": "Angular velocity.",
        "type": "float"
      },
      {
        "name": "left_contact",
        "description": "Whether the left leg contacts ground.",
        "type": "bool"
      },
      {
        "name": "right_contact",
        "description": "Whether the right leg contacts ground.",
        "type": "bool"
      }
    ],
    "action_variables": [
      {
        "name": "main_engine",
        "description": "Main engine action or throttle.",
        "type": "float"
      },
      {
        "name": "side_engine",
        "description": "Side engine action or throttle.",
        "type": "float"
      }
    ],
    "allowed_formula_variables": [
      "x",
      "y",
      "vx",
      "vy",
      "angle",
      "angular_velocity",
      "left_contact",
      "right_contact",
      "main_engine",
      "side_engine"
    ],
    "allowed_formula_functions": [
      "abs",
      "min",
      "max",
      "clip",
      "sqrt",
      "exp",
      "tanh"
    ],
    "allowed_component_types_v2": [
      "formula_component",
      "conditional_formula_component",
      "event_predicate"
    ],
    "bootstrap_requirements": {
      "must_generate_initial_schema": true,
      "must_generate_diagnostic_predicates": true,
      "must_assign_semantic_roles": true,
      "must_include_hacking_risk_notes": true,
      "official_environment_reward_forbidden_as_feedback": true,
      "posthoc_oracle_evaluation_allowed": true,
      "no_v1_schema_exposure": true,
      "no_v1_diagnostic_metric_exposure": true,
      "no_v1_task_description_file_exposure": true,
      "formula_must_use_only_primitive_variables": true
    },
    "semantic_roles": [
      "dense_guidance",
      "stability_quality",
      "terminal_success",
      "safety_constraint",
      "control_cost"
    ],
    "observation_mapping": {
      "x": 0,
      "y": 1,
      "vx": 2,
      "vy": 3,
      "angle": 4,
      "angular_velocity": 5,
      "left_contact": 6,
      "right_contact": 7
    },
    "bootstrap_interface_policy": {
      "principle": "V2 avoids previous-schema leakage by interface isolation. The bootstrap agent only receives primitive observation/action variables, safe formula functions, task text, and output format constraints.",
      "formula_boundary": "Generated formulas must use only allowed_formula_variables and allowed_formula_functions.",
      "not_exposed_to_llm": [
        "previous initial reward schema content",
        "previous diagnostic metric definitions",
        "previous event predicate definitions",
        "previous task-specific reward-design files"
      ]
    },
    "action_cost_policy_v2": {
      "custom_action_cost": "Use formula_component with semantic_role='control_cost'.",
      "legacy_action_penalty": "Do not use for LLM-generated custom formulas; runtime action_penalty is built-in -sum(action^2)."
    },
    "action_mapping": {
      "type": "discrete_lookup",
      "variables": {
        "main_engine": {
          "2": 1.0,
          "default": 0.0
        },
        "side_engine": {
          "1": -1.0,
          "3": 1.0,
          "default": 0.0
        }
      }
    }
  },
  "primitive_interface_path": "configs/eg_rsa_examples/lunar_lander_primitive_interface.json"
}