      "weight": 1.0,
      "formula": "-0.005 * min(sqrt(x*x + y*y), 10)",
      "enabled": true,
      "params": {
        "formula": "-0.005 * min(sqrt(x*x + y*y), 10)"
      }
    },
    {
      "type": "formula_component",
      "name": "stability_quality",
      "role": "stability_quality",
      "weight": 1.0,
      "formula": "-0.01 * (abs(angle) + abs(angular_velocity) + abs(vx))",
      "enabled": true,
      "params": {
        "formula": "-0.01 * (abs(angle) + abs(angular_velocity) + abs(vx))"
      }
    },
    {
      "type": "conditional_formula_component",
      "name": "soft_landing_vertical",
      "role": "stability_quality",
      "condition": "y < 0.5",
      "formula": "-0.1 * abs(vy)",
      "weight": 1.0,
      "enabled": true,
      "params": {
        "formula": "-0.1 * abs(vy)",
        "condition": "y < 0.5"
      }
    },
    {
      "type": "action_penalty",
      "name": "fuel_cost",
      "role": "control_cost",
      "weight": 0.05,
      "formula": "abs(main_engine) + abs(side_engine)",
      "enabled": true,
      "params": {
        "formula": "abs(main_engine) + abs(side_engine)"
      }
    }
  ],
  "event_rules": [
    {
      "type": "event_predicate",
      "name": "soft_landing_success",
      "condition": {
        "expression": "left_contact and right_contact and abs(vx) < 0.2 and abs(vy) < 0.2 and abs(angle) < 0.1",
