{
  "version": 2,
  "metadata": {
    "source": "llm_bootstrap",
    "task": "LunarLander-v3",
    "reward_blueprint_present": true
  },
  "components": [
    {
      "name": "r_progress",
      "type": "formula_component",
      "variables": [
        "vy",
        "y"
      ],
      "formula": "tanh(-vy) * clip(y, 0, 1)",
      "weight": 1.0,
      "enabled": true,
      "params": {
        "formula": "tanh(-vy) * clip(y, 0, 1)"
      }
    },
    {
      "name": "r_centering",
      "type": "formula_component",
      "variables": [
        "x",
        "y"
      ],
      "formula": "-abs(x) * (1 - clip(y, 0, 1))",
      "weight": 1.0,
      "enabled": true,
      "params": {
        "formula": "-abs(x) * (1 - clip(y, 0, 1))"
      }
    },
    {
      "name": "r_stability",
      "type": "formula_component",
      "variables": [
        "angle",
        "angular_velocity"
      ],
      "formula": "-abs(angle) - 0.1 * abs(angular_velocity)",
      "weight": 1.0,
      "enabled": true,
      "params": {
        "formula": "-abs(angle) - 0.1 * abs(angular_velocity)"
      }
    },
    {
      "name": "r_action_cost",
      "type": "action_penalty",
      "variables": [
        "main_engine",
        "side_engine"
      ],
      "formula": "-0.3 * abs(main_engine) - 0.3 * abs(side_engine)",
      "weight": 1.0,
      "enabled": true,
      "params": {
        "formula": "-0.3 * abs(main_engine) - 0.3 * abs(side_engine)"
      }
    },
    {
      "name": "r_soft_touchdown",
      "type": "conditional_formula_component",
      "variables": [
        "left_contact",
        "right_contact",
        "vy",
        "vx"
      ],
      "condition": "left_contact or right_contact",
      "formula": "-(abs(vy) + 0.2 * abs(vx))",
      "weight": 1.0,
      "enabled": true,
      "params": {
        "formula": "-(abs(vy) + 0.2 * abs(vx))",
        "condition": "left_contact or right_contact"
      }
    }
  ],
  "event_rules": [
    {
      "name": "terminal_success",
      "type": "event_predicate",
      "variables": [
        "left_contact",
        "right_contact",
        "vy",
        "angle",
        "x"
      ],
      "condition": {
        "expression": "left_contact and right_contact and abs(vy) < 0.2 and abs(angle) < 0.1 and abs(x) < 0.2",
        "duration_steps": 1
      },
      "reward": 100.0,
      "enabled": true,
      "weight": 1.0,
      "one_time": true
    }
  ]
}