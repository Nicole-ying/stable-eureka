      "reward": 100,
      "enabled": true,
      "weight": 1.0,
      "one_time": true
    },
    {
      "type": "event_predicate",
      "name": "hard_landing_penalty",
      "condition": {
        "expression": "left_contact and right_contact and (abs(vy) > 1.0 or abs(vx) > 1.0)",
        "duration_steps": 1
      },
      "reward": -100,
      "enabled": true,
      "weight": 1.0,
      "one_time": true
    }
  ]
