  "reward_error_fallback": "original",
  "reward_repair_attempts": 2,
  "num_seeds": 3,
  "feedback_mode": "diagnostic",
  "reward_structure": "hrdc",
  "training_algorithm": "ppo",
  "force_iterations_before_patience": 3,
  "output_dir": "outputs/lunarlander_stress"
}
